    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "Column"@en .

min:External-Data a owl:Class ;
    rdfs:label "External-Data"@en ;
    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "External-Data"@en ;
    rdfs:subClassOf min:Data-Table .

min:Instrument-Model a owl:Class ;
    rdfs:label "Instrument-Model"@en ;
    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "Instrument-Model"@en .

