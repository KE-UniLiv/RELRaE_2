    rdfs:label "Database"@en ;
    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "Database"@en ;
    rdfs:comment """
       The database element is used to define the databases which give 
       context to the accessions.
    """@en .

min:Channel a owl:Class ;
