    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "Contributor-Ref"@en ;
    rdfs:subClassOf min:Platform,
        min:Series .

min:Organization a owl:Class ;
    rdfs:label "Organization"@en ;
    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "Organization"@en ;
    rdfs:comment """
      The Organization element provides a central location for defining the
      organization to which one or more of the the contributors belong. An
      organaztion only needs to be defined once in the document.
    """@en .

min:Sample-Ref a owl:Class ;
    rdfs:label "Sample-Ref"@en ;
    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "Sample-Ref"@en ;
    rdfs:comment """
             Submission Guidelines: Reference all the Sample iid that make 
             up this Series.
           """@en .

min:External-File a owl:Class ;
    rdfs:label "External-File"@en ;
    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "External-File"@en ;
