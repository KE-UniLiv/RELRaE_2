    rdfs:label "Internal-Data"@en ;
    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "Internal-Data"@en ;
    rdfs:subClassOf min:Data-Table .

min:Organism a owl:Class ;
    rdfs:label "Organism"@en ;
    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "Organism"@en ;
    rdfs:comment """
              Submission Guidelines: Identify the organism(s) from which the 
              features on the Platform were designed or derived. Use standard 
              NCBI Taxonomy nomenclature.
            """@en,
        """
          Submission Guidelines: Identify the organism(s) from which
          the biological material was derived. Use standard NCBI
          Taxonomy nomenclature.
        """@en .

min:Organization-Ref a owl:Class ;
    rdfs:label "Organization-Ref"@en ;
    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "Organization-Ref"@en ;
    rdfs:subClassOf min:Contact,
        min:Contributor,
        min:Database .

min:Platform-Ref a owl:Class ;
    rdfs:label "Platform-Ref"@en ;
    min:generatedBy "Rubrex"@en ;
    min:hasXSDSource "Platform-Ref"@en ;
    rdfs:comment """
             Submission Guidelines: Reference the Platform iid upon which 
